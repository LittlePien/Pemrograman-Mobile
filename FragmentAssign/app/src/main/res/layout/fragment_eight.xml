<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/tv_fragment_eight"
        android:text="@string/tv_fragment_eight"
        android:textSize="32sp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/btn_next"
        android:text="@string/btn_next"
        app:layout_constraintStart_toStartOf="@id/tv_fragment_eight"
        app:layout_constraintTop_toBottomOf="@id/tv_fragment_eight"
        app:layout_constraintEnd_toEndOf="@id/tv_fragment_eight"/>

</androidx.constraintlayout.widget.ConstraintLayout>